CC = gcc
CFLAGS = -Wall -Wextra -std=gnu11 -g -I./cJSON -I/usr/include/dilithium
LDFLAGS = -lpqcrystals_dilithium5_ref -lpqcrystals_fips202_ref -lcurl

SRCDIR = .
CJSONDIR = ./cJSON
SRC = $(SRCDIR)/bob.c $(SRCDIR)/core/connection_qkd.c $(SRCDIR)/core/handle_json.c $(CJSONDIR)/cJSON.c $(SRCDIR)/core/cryptografy.c $(SRCDIR)/core/handle_msg.c $(SRCDIR)/core/sign_dilithium.c
OBJS = $(SRC:.c=.o)
TARGET = bob

.PHONY: all clean run

all: $(TARGET)

$(TARGET): $(OBJS)
	$(CC) $(CFLAGS) -o $@ $^ $(LDFLAGS)

%.o: %.c
	$(CC) $(CFLAGS) -c $< -o $@

clean:
	rm -f $(OBJS) $(TARGET)

run: $(TARGET)
	./$(TARGET)